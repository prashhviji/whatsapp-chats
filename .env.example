# Copy this file to .env.local and fill in your key.
# Get a key at https://aistudio.google.com/apikey
#
# IMPORTANT: use a PAID (billing-enabled) key for real use. The free tier may use
# your data for training and was heavily rate-limited in Dec 2025. This key is
# read only on the server (never shipped to the browser).
GEMINI_API_KEY=
